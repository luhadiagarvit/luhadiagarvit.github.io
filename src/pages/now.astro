---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Now",
	description: "What Garvit Luhadia is up to right now.",
};

const lastUpdated = new Date("2026-04-18");
const dateFmt = lastUpdated.toLocaleDateString("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
});
---

<PageLayout meta={meta}>
	<section class="max-w-prose">
		<h1 class="title mb-6 text-2xl">Now</h1>
		<p class="text-muted mb-8 text-sm leading-relaxed">
			A <a class="cactus-link" href="https://nownownow.com/about" rel="noreferrer" target="_blank">/now page</a>
			&mdash; what I'm focused on this quarter.
		</p>

		<h2 class="title text-accent mt-8 mb-2 text-lg">Work</h2>
		<p class="text-sm leading-relaxed">
			Shipping on-device real-time machine translation for UN field personnel
			&mdash; ONNX-optimized small language models, sub-500&nbsp;ms latency,
			hybrid cloud-edge MLOps.
		</p>

		<h2 class="title text-accent mt-8 mb-2 text-lg">Research</h2>
		<p class="text-sm leading-relaxed">
			Reading about low-resource MT, quantization-aware training, and
			federated fine-tuning. Interested in what ships to constrained
			devices without giving up capability.
		</p>

		<h2 class="title text-accent mt-8 mb-2 text-lg">Photography</h2>
		<p class="text-sm leading-relaxed">
			Shooting mostly film this year. New York streets, mountain trips.
			The output lives on <a class="cactus-link" href="/photos/">/photos</a>.
		</p>

		<h2 class="title text-accent mt-8 mb-2 text-lg">Reading</h2>
		<p class="text-sm leading-relaxed">
			Rotating non-fiction (operations research, history of cartography)
			and the occasional novel.
		</p>

		<p class="text-muted mt-10 text-xs">Last updated {dateFmt}.</p>
	</section>
</PageLayout>
