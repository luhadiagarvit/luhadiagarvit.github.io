---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

const posts = await getCollection("post", ({ data }) => !data.draft);

const counts = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		counts.set(tag, (counts.get(tag) ?? 0) + 1);
	}
}
const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const meta = {
	title: "Tags",
	description: "All tags.",
};
---

<PageLayout meta={meta}>
	<section class="mb-10">
		<h1 class="title mb-4 text-2xl">Tags</h1>
	</section>

	{
		tags.length === 0 ? (
			<p class="text-muted max-w-prose text-sm italic">No tags yet.</p>
		) : (
			<ul class="flex max-w-prose flex-wrap gap-x-3 gap-y-2 text-sm" role="list">
				{tags.map(([tag, count]) => (
					<li>
						<a class="cactus-link" href={`/tags/${tag}/`}>
							#{tag}
							<span class="text-muted"> ({count})</span>
						</a>
					</li>
				))}
			</ul>
		)
	}
</PageLayout>
