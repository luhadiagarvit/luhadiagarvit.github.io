---
import LastCommit from "@/components/chrome/LastCommit.astro";
import SocialList from "@/components/SocialList.astro";
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="text-muted mt-auto flex w-full flex-col items-start justify-between gap-y-4 border-t border-dashed border-muted/30 pt-8 pb-6 text-xs sm:flex-row sm:items-center"
>
	<div class="flex flex-col gap-y-1">
		<div>&copy; {year} {siteConfig.author}</div>
		<LastCommit />
	</div>
	<SocialList />
</footer>
