---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { menuLinks, siteConfig } from "@/site.config";
---

<header class="relative mb-16 flex flex-col gap-y-4 sm:mb-20 sm:flex-row sm:items-center sm:justify-between" id="main-header">
	<a
		aria-current={Astro.url.pathname === "/" ? "page" : false}
		class="inline-flex items-baseline gap-x-2"
		href="/"
	>
		<span class="text-base font-semibold tracking-tight">{siteConfig.title}</span>
		<span class="text-muted hidden text-xs sm:inline">/ luhadiagarvit</span>
	</a>
	<div class="flex items-center gap-x-4">
		<nav aria-label="Main menu">
			<ul class="flex flex-wrap gap-x-4 text-xs sm:text-sm" role="list">
				{
					menuLinks
						.filter((link) => link.path !== "/")
						.map((link) => (
							<li>
								<a
									aria-current={Astro.url.pathname.startsWith(link.path) && link.path !== "/" ? "page" : false}
									class="text-muted hover:text-accent aria-[current=page]:text-accent"
									href={link.path}
								>
									{link.title}
								</a>
							</li>
						))
				}
			</ul>
		</nav>
		<ThemeToggle />
	</div>
</header>
